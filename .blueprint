created:
    - database/factories/ProductFactory.php
    - database/factories/RegionFactory.php
    - database/factories/SupplierFactory.php
    - database/factories/SupplierPaymentFactory.php
    - database/factories/CustomerFactory.php
    - database/factories/CustomerPaymentFactory.php
    - database/factories/PurchaseFactory.php
    - database/factories/SaleFactory.php
    - database/migrations/2026_06_30_111629_create_products_table.php
    - database/migrations/2026_06_30_111630_create_regions_table.php
    - database/migrations/2026_06_30_111631_create_suppliers_table.php
    - database/migrations/2026_06_30_111632_create_supplier_payments_table.php
    - database/migrations/2026_06_30_111633_create_customers_table.php
    - database/migrations/2026_06_30_111634_create_customer_payments_table.php
    - database/migrations/2026_06_30_111635_create_purchases_table.php
    - database/migrations/2026_06_30_111636_create_sales_table.php
